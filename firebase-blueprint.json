{
  "entities": {
    "ExercisePlan": {
      "title": "ExercisePlan",
      "description": "A planned exercise for a specific day of the week.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID of the plan" },
        "name": { "type": "string", "description": "Name of the exercise" },
        "dayOfWeek": { "type": "string", "description": "Day of the week" },
        "dateAdded": { "type": "string", "description": "ISO date string when added" },
        "muscleGroup": { "type": "string", "description": "Muscle category" },
        "userId": { "type": "string", "description": "Owner ID" }
      },
      "required": ["id", "name", "dayOfWeek", "dateAdded", "muscleGroup", "userId"]
    },
    "ExerciseLog": {
      "title": "ExerciseLog",
      "description": "A logged performance of an exercise.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "ID of the log" },
        "planId": { "type": "string", "description": "ID of the plan" },
        "name": { "type": "string", "description": "Name of the exercise" },
        "weight": { "type": "number", "description": "Weight lifted" },
        "unit": { "type": "string", "description": "Unit of weight (kg/lbs)" },
        "reps": { "type": "number", "description": "Number of reps" },
        "steps": { "type": "number", "description": "Number of steps" },
        "duration": { "type": "number", "description": "Duration in minutes" },
        "date": { "type": "string", "description": "ISO date string when logged" },
        "muscleGroup": { "type": "string", "description": "Muscle category" },
        "userId": { "type": "string", "description": "Owner ID" }
      },
      "required": ["id", "planId", "name", "date", "muscleGroup", "userId"]
    },
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information including username for friend search.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "username": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "searchableUsername": { "type": "string", "description": "Lowercase username for searching" }
      },
      "required": ["uid", "username", "searchableUsername"]
    },
    "Friendship": {
      "title": "Friendship",
      "description": "A connection between two users.",
      "type": "object",
      "properties": {
        "friendId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "accepted"] },
        "createdAt": { "type": "string" }
      },
      "required": ["friendId", "status", "createdAt"]
    },
    "NutritionLog": {
      "title": "NutritionLog",
      "description": "A logged meal or water intake.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string" },
        "mealType": { "type": "string", "enum": ["breakfast", "lunch", "dinner", "snack"] },
        "foodItems": { "type": "array" },
        "totalCalories": { "type": "number" },
        "totalProtein": { "type": "number" },
        "totalCarbs": { "type": "number" },
        "totalFat": { "type": "number" },
        "waterIntakeMl": { "type": "number" },
        "feedback": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "userId", "date", "mealType", "foodItems", "totalCalories", "totalProtein", "totalCarbs", "totalFat", "waterIntakeMl", "feedback"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/UserProfile" },
      "description": "User profile data"
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": { "$ref": "#/entities/Friendship" },
      "description": "User's friends"
    },
    "/users/{userId}/plans/{planId}": {
      "schema": { "$ref": "#/entities/ExercisePlan" },
      "description": "User's exercise plans"
    },
    "/users/{userId}/logs/{logId}": {
      "schema": { "$ref": "#/entities/ExerciseLog" },
      "description": "User's exercise logs"
    },
    "/users/{userId}/nutrition/{logId}": {
      "schema": { "$ref": "#/entities/NutritionLog" },
      "description": "User's nutrition logs"
    },
    "/pro_users/{userId}": {
      "schema": {
        "title": "ProUser",
        "description": "Pro subscription status",
        "type": "object",
        "properties": {
          "active": { "type": "boolean" },
          "createdAt": { "type": "string" }
        },
        "required": ["active", "createdAt"]
      },
      "description": "Pro subscription status"
    },
    "/vip/{email}": {
      "schema": {
        "title": "VipUser",
        "description": "VIP status for specific emails",
        "type": "object",
        "properties": {
          "active": { "type": "boolean" },
          "email": { "type": "string" }
        },
        "required": ["active", "email"]
      },
      "description": "VIP status for specific emails"
    }
  }
}
